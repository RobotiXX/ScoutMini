<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="scout_wheel">

    <xacro:macro name="scout_mini_wheel" params="wheel_prefix wheel_axis:='0 0 -1' *joint_pose">
        <link name="${wheel_prefix}_wheel_link">
            <inertial>
                <mass value="3" />
                <origin xyz="0 0 0" />
                <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.7171" iyz="0" izz="0.1361" />
            </inertial>
            <visual>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <mesh filename="file://$(find scoutmini_description)/meshes/wheel.dae" />
                </geometry>
            </visual>
            <collision>
              <origin
                xyz="0 0 0"
                rpy="0 0 0" />
              <geometry>
                <mesh
                  filename="file://$(find scoutmini_description)/meshes/wheel.dae" />
              </geometry>
            </collision>
        </link>

        <joint name="${wheel_prefix}_wheel" type="continuous">
            <parent link="base_link"/>
            <child link="${wheel_prefix}_wheel_link"/>
            <xacro:insert_block name="joint_pose"/>
            <axis xyz="${wheel_axis}" rpy="0 0 0" />
        </joint>

        <gazebo reference="${wheel_prefix}_wheel_link">
            <mu1 value="1.0"/>
            <mu2 value="0.08"/>
            <slip1 value="0.0"/>
            <slip2 value="0.4"/>
            <kp value="500000.0"/>
            <kd value="20.0"/>
            <minDepth value="0.001"/>
            <maxContacts value="8"/>
        </gazebo>
    </xacro:macro>

</robot>
