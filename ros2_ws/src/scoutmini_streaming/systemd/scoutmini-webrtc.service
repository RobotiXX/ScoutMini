[Unit]
Description=ScoutMini ZED WebRTC gateway
After=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
Environment=SCOUT_REPO_ROOT=@REPO_ROOT@
ExecStart=@REPO_ROOT@/ros2_ws/install/scoutmini_streaming/share/scoutmini_streaming/scripts/start_zed_webrtc_stack.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
