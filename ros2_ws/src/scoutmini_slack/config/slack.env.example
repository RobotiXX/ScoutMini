# Copy this to /home/nvidia/repos/ScoutMini/.local/secrets/slack.env
# and fill in the real values locally. Do not commit real tokens.

export SLACK_BOT_TOKEN='xoxb-your-token-here'
export SLACK_APP_TOKEN='xapp-your-token-here'
export SLACK_CHANNEL_ID='C-your-channel-id-here'
export SCOUT_STREAM_URL='http://<robot_ip_or_tailscale_ip>:8889/zed/'
export SCOUT_STREAM_CONTROL_SCRIPT='/home/nvidia/repos/ScoutMini/ros2_ws/src/scoutmini_slack/scripts/control_zed_stream.sh'
